{
  "name": "cinematic-drama-app",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform interactive short-drama viewer for AI-generated timeline experiences.",
  "license": "Apache-2.0",
  "author": "ClipHound",
  "homepage": "https://github.com/ClipHound/cinematic-drama#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClipHound/cinematic-drama.git",
    "directory": "cinematic-drama-app-frontend-source"
  },
  "bugs": {
    "url": "https://github.com/ClipHound/cinematic-drama/issues"
  },
  "keywords": ["react", "capacitor", "interactive-video", "short-drama", "ai"],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:aab": "npm run android:sync && cd android && gradlew.bat bundleRelease"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/status-bar": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^0.560.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.12"
  }
}
