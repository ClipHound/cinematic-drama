# Django runtime
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1:5174

# Optional production database. Leave empty for local SQLite.
DATABASE_URL=

# Legacy/offline artifacts root. Point this to your drama-understanding-agent checkout.
LEGACY_AGENT_ROOT=../drama-understanding-agent
AI_RAG_DELIVERY_SOURCE=

# OpenAI-compatible chat API, e.g. SiliconFlow.
AI_CHAT_BASE_URL=https://api.siliconflow.cn/v1
AI_CHAT_API_KEY=
AI_CHAT_MODEL=

# OpenAI-compatible embedding API, e.g. SiliconFlow.
AI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=
# Optional. Leave 0 to use provider/model default dimensions.
AI_EMBEDDING_DIMENSIONS=0
AI_HTTP_TIMEOUT_SECONDS=30
AI_HTTP_MAX_RETRIES=2
AI_HTTP_RETRY_BASE_SECONDS=0.8
