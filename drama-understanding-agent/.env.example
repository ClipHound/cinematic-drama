DRAMA_AGENT_PROJECTS_ROOT=./projects

# Same semantics as server/.env.example: base endpoint, token, and endpoint-id/model.
# The client appends /chat/completions, /files, or /responses as needed.
DRAMA_AGENT_MODEL_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DRAMA_AGENT_MODEL_TOKEN=
DRAMA_AGENT_MODEL_NAME=YOUR_DOUBAO_VISION_MODEL_OR_ENDPOINT_ID

# Also supported directly, so this package can reuse server/.env values:
# AI_VLM_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# AI_VLM_TOKEN=YOUR_ARK_API_KEY
# AI_VLM_MODEL=YOUR_DOUBAO_VISION_MODEL_OR_ENDPOINT_ID

DRAMA_AGENT_QDRANT_HOST=localhost
DRAMA_AGENT_QDRANT_PORT=6333
DRAMA_AGENT_EMBED_ENDPOINT=http://localhost:11434
DRAMA_AGENT_EMBED_MODEL=qwen3-embedding:0.6b
DRAMA_AGENT_ASR_ENDPOINT=
DRAMA_AGENT_MODE=full_auto
